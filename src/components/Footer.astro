---
import { getCollection } from 'astro:content';
import { navigation, site } from '../data/site';

const publishedNews = (await getCollection('noticias', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const calendarBaseDate = publishedNews[0]?.data.date ?? new Date();
const calendarYear = calendarBaseDate.getFullYear();
const calendarMonth = calendarBaseDate.getMonth();
const calendarMonthLabel = calendarBaseDate.toLocaleDateString('es-AR', {
  month: 'long',
  year: 'numeric',
});
const firstDay = new Date(calendarYear, calendarMonth, 1);
const daysInMonth = new Date(calendarYear, calendarMonth + 1, 0).getDate();
const mondayStartOffset = (firstDay.getDay() + 6) % 7;
const newsDates = new Set(
  publishedNews
    .filter((post) => post.data.date.getFullYear() === calendarYear && post.data.date.getMonth() === calendarMonth)
    .map((post) => post.data.date.toISOString().slice(0, 10))
);
const calendarDays = [
  ...Array.from({ length: mondayStartOffset }, () => null),
  ...Array.from({ length: daysInMonth }, (_, index) => {
    const day = index + 1;
    const iso = new Date(calendarYear, calendarMonth, day).toISOString().slice(0, 10);
    return { day, iso, hasNews: newsDates.has(iso) };
  }),
];
const weekDays = ['L', 'M', 'M', 'J', 'V', 'S', 'D'];
const socialLinks = [
  { label: 'Sitio Web', href: '/', icon: '/images/icons/www.png' },
  { label: 'Instagram', href: site.social.instagram, icon: '/images/icons/instagram.png', external: true },
  { label: 'Facebook', href: site.social.facebook, icon: '/images/icons/facebook.png', external: true },
  { label: 'Feed Noticias', href: '/noticias/', icon: '/images/icons/noticias.png' },
  { label: 'Correo', href: site.social.email, icon: '/images/icons/gmail.png', external: true },
];
---

<footer class="footer">
  <div class="container footer__grid">
    <section class="footer__about" aria-labelledby="footer-name">
      <span class="footer__mark"><img src="/images/branding/logo-redisenado.png" alt="" width="70" height="70" /></span>
      <h2 id="footer-name">{site.name}</h2>
      <p>{site.description}</p>
      <address><strong>Dirección</strong><br />{site.address}</address>
    </section>

    <section aria-labelledby="footer-contact">
      <h2 id="footer-contact">Contacto</h2>
      <ul>
        <li><span>Informes e Inscripción</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><span>Teléfonos</span>{site.phones.map((phone) => <a href={phone.href}>{phone.label}</a>)}</li>
      </ul>
    </section>

    <section aria-labelledby="footer-links">
      <h2 id="footer-links">Sitio Web</h2>
      <nav aria-label="Enlaces del pie">
        <ul>
          {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href={site.campusUrl} target="_blank" rel="noopener noreferrer">Campus Virtual ↗</a></li>
        </ul>
      </nav>
    </section>

    <section aria-labelledby="footer-calendar">
      <h2 id="footer-calendar">Calendario de noticias</h2>
      <p class="calendar-caption">{calendarMonthLabel}</p>
      <div class="mini-calendar" aria-label={`Calendario de noticias de ${calendarMonthLabel}`}>
        {weekDays.map((day) => <span class="mini-calendar__weekday">{day}</span>)}
        {calendarDays.map((item) => item ? (
          <span class:list={['mini-calendar__day', { 'mini-calendar__day--news': item.hasNews }]} aria-label={item.hasNews ? `Día ${item.day} con noticia publicada` : `Día ${item.day}`}>
            {item.day}
          </span>
        ) : (
          <span class="mini-calendar__empty" aria-hidden="true"></span>
        ))}
      </div>
      <p class="calendar-help">Los días marcados indican que hay una noticia publicada.</p>
    </section>
  </div>

  <div class="container footer__social">
    <strong>Informes Web</strong>
    {socialLinks.map((link) => (
      <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
        <img src={link.icon} alt="" width="18" height="18" loading="lazy" />
        <span>{link.label}{link.external ? ' ↗' : ''}</span>
      </a>
    ))}
  </div>

  <div class="container footer__legal">
    <p>© {new Date().getFullYear()} {site.name}</p>
    <div><a href="/privacidad/">Privacidad</a><span>Créditos institucionales</span></div>
  </div>
</footer>

<style>
  .footer { padding: clamp(1.5rem, 3vw, 2.5rem) 0 1.25rem; background: var(--color-bg-primary); color: var(--color-text-inverse); }
  .footer__grid { display: grid; grid-template-columns: 1.5fr .9fr .75fr 1.05fr; gap: var(--space-column-gap); }
  .footer h2 { margin-bottom: 1.25rem; font-size: .95rem; letter-spacing: 0; }
  .footer__about h2 { max-width: 400px; font-size: 1.15rem; }
  .footer__about > p { max-width: 480px; color: var(--color-text-inverse-soft); font-size: .9rem; }
  .footer__mark { display: grid; width: 74px; height: 74px; margin-bottom: 1.2rem; place-items: center; }
  .footer__mark img { width: 70px; height: 70px; object-fit: contain; }
  address { margin-top: 1.4rem; color: var(--color-text-inverse-soft); font-style: normal; font-size: .88rem; }
  address strong { color: var(--color-text-inverse); }
  ul { display: grid; gap: .65rem; margin: 0; padding: 0; list-style: none; }
  li span { display: block; color: var(--color-accent); font-size: .72rem; }
  li a { display: block; color: var(--color-link-inverse); font-size: .86rem; }
  a:hover { color: var(--color-link-inverse-hover); text-decoration: underline; text-underline-offset: .2rem; }
  .calendar-caption { margin-bottom: .7rem; color: var(--color-link-inverse); font-size: .84rem; font-weight: 800; text-transform: capitalize; }
  .mini-calendar { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: .28rem; max-width: 230px; }
  .mini-calendar__weekday { color: var(--color-accent); font-size: .68rem; font-weight: 900; text-align: center; }
  .mini-calendar__day, .mini-calendar__empty { display: grid; min-height: 1.8rem; place-items: center; border-radius: 999px; font-size: .76rem; }
  .mini-calendar__day { color: var(--color-text-inverse-soft); }
  .mini-calendar__day--news { position: relative; background: var(--color-error); color: var(--color-button-primary-text); font-weight: 900; }
  .mini-calendar__day--news::after { position: absolute; inset: -.22rem; border: 1px solid var(--color-error); border-radius: inherit; content: ''; animation: news-pulse 1.6s ease-out infinite; }
  .calendar-help { max-width: 230px; margin-top: .75rem; color: var(--color-text-inverse-soft); font-size: .74rem; line-height: 1.45; }
  .footer__social { display: flex; flex-wrap: wrap; gap: .8rem 1.4rem; margin-top: var(--space-block); padding: 1.25rem 0; border-block: 1px solid var(--color-border-inverse); color: var(--color-text-inverse-soft); font-size: .82rem; }
  .footer__social strong { color: var(--color-text-inverse); }
  .footer__social a { display: inline-flex; align-items: center; gap: .4rem; color: var(--color-link-inverse); }
  .footer__social img { width: 18px; height: 18px; object-fit: contain; }
  .footer__legal { display: flex; justify-content: space-between; gap: 1rem; padding-top: 1.25rem; color: var(--color-link-inverse); font-size: .74rem; }
  .footer__legal div { display: flex; gap: 1.2rem; }
  @keyframes news-pulse {
    0% { opacity: .85; transform: scale(.92); }
    100% { opacity: 0; transform: scale(1.45); }
  }
  @media (max-width: 980px) { .footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .footer__grid { grid-template-columns: 1fr; gap: 2rem; }.footer__legal { flex-direction: column; }.footer__legal div { flex-wrap: wrap; } }
</style>
