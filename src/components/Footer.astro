---
import { calendarEvents, navigation, site } from '../data/site';
---
<footer class="footer">
  <div class="container footer__grid">
    <section class="footer__about" aria-labelledby="footer-name">
      <span class="footer__mark"><img src="/images/branding/logo-redisenado.png" alt="" width="70" height="70" /></span>
      <h2 id="footer-name">{site.name}</h2>
      <p>{site.description}</p>
      <address><strong>Dirección</strong><br />{site.address}</address>
    </section>
    <section aria-labelledby="footer-contact"><h2 id="footer-contact">Contacto</h2><ul>
      <li><span>Informes e Inscripción</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
      <li><span>Teléfonos</span>{site.phones.map((phone) => <a href={phone.href}>{phone.label}</a>)}</li>
    </ul></section>
    <section aria-labelledby="footer-links"><h2 id="footer-links">Sitio Web</h2><nav aria-label="Enlaces del pie"><ul>{navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}<li><a href={site.campusUrl} target="_blank" rel="noopener noreferrer">Campus Virtual ↗</a></li></ul></nav></section>
    <section aria-labelledby="footer-calendar"><h2 id="footer-calendar">Calendario</h2>
      {calendarEvents.length ? <ul class="events">{calendarEvents.slice(0,3).map((event) => <li><time datetime={event.date}>{new Date(`${event.date}T12:00:00`).toLocaleDateString('es-AR', { day:'2-digit', month:'short' })}</time><span>{event.title}</span></li>)}</ul> : <div class="calendar-empty"><span aria-hidden="true">□</span><p>No hay actividades publicadas actualmente.</p></div>}
      <a class="footer__link" href="/calendario/">Ver calendario completo →</a>
    </section>
  </div>
  <div class="container footer__social"><strong>Informes Web</strong><a href="/">Sitio Web</a><a href={site.social.instagram} target="_blank" rel="noopener noreferrer">Instagram ↗</a><a href={site.social.facebook} target="_blank" rel="noopener noreferrer">Facebook ↗</a><a href="/noticias/">Feed Noticias</a><a href={site.social.email} target="_blank" rel="noopener noreferrer">Correo ↗</a></div>
  <div class="container footer__legal"><p>© {new Date().getFullYear()} {site.name}</p><div><a href="/privacidad/">Privacidad</a><span>Créditos institucionales</span></div></div>
</footer>
<style>
  .footer { padding: 4.5rem 0 1.25rem; background: var(--ink); color: var(--white); }
  .footer__grid { display: grid; grid-template-columns: 1.7fr 1fr .75fr 1.2fr; gap: 3rem; }
  .footer h2 { margin-bottom: 1.25rem; font-size: .95rem; letter-spacing: 0; }
  .footer__about h2 { max-width: 400px; font-size: 1.15rem; }
  .footer__about > p { max-width: 480px; color: #b9cbc1; font-size: .9rem; }
  .footer__mark { display: grid; width: 74px; height: 74px; margin-bottom: 1.2rem; place-items: center; }
  .footer__mark img { width: 70px; height: 70px; object-fit: contain; }
  address { margin-top: 1.4rem; color: #b9cbc1; font-style: normal; font-size: .88rem; } address strong { color: var(--white); }
  ul { display: grid; gap: .65rem; margin: 0; padding: 0; list-style: none; }
  li span { display: block; color: #8da69b; font-size: .72rem; }
  li a { display: block; color: #d8e4dc; font-size: .86rem; }
  a:hover { color: var(--mint); text-decoration: underline; text-underline-offset: .2rem; }
  .calendar-empty { padding: 1rem; border: 1px solid rgba(142,182,155,.25); border-radius: .8rem; color: #b9cbc1; font-size: .82rem; }
  .calendar-empty span { color: var(--mint); font-size: 1.3rem; }
  .events li { display: grid; grid-template-columns: 50px 1fr; gap: .6rem; }.events time { color: var(--mint); font-weight: 700; }.events span { color: #d8e4dc; }
  .footer__link { display: inline-block; margin-top: 1rem; color: var(--mint); font-size: .82rem; font-weight: 700; }
  .footer__social { display: flex; flex-wrap: wrap; gap: .8rem 1.4rem; margin-top: 3.5rem; padding: 1.25rem 0; border-block: 1px solid rgba(255,255,255,.12); color: #bdcec4; font-size: .82rem; }.footer__social strong { color: var(--white); }
  .footer__legal { display: flex; justify-content: space-between; gap: 1rem; padding-top: 1.25rem; color: #81978c; font-size: .74rem; }.footer__legal div { display: flex; gap: 1.2rem; }
  @media (max-width: 980px) { .footer__grid { grid-template-columns: 1.5fr 1fr; } }
  @media (max-width: 620px) { .footer__grid { grid-template-columns: 1fr; gap: 2.5rem; }.footer__legal { flex-direction: column; }.footer__legal div { flex-wrap: wrap; } }
</style>
