---
import Navbar from './Navbar.astro';
import { site } from '../data/site';
---
<header class="site-header">
  <div class="topbar">
    <div class="container topbar__inner">
      <p>Formación superior sanitaria en Formosa</p>
      <div><a href={`mailto:${site.email}`}>{site.email}</a><span aria-hidden="true">·</span><a href={site.phones[0].href}>{site.phones[0].label}</a></div>
    </div>
  </div>
  <div class="header-main">
    <div class="container header-main__inner">
      <a class="brand" href="/" aria-label={`${site.shortName}, inicio`}>
        <img class="brand__logo" src="/images/branding/logo-redisenado.png" alt="" width="58" height="58" />
        <span class="brand__text"><strong>Instituto Superior de Sanidad</strong><small>Prof. Dr. Ramón Carrillo · Fundación HAC</small></span>
      </a>
      <Navbar />
    </div>
  </div>
</header>
<style>
  .site-header { position: sticky; top: 0; z-index: 50; box-shadow: 0 1px 0 var(--color-border-soft); }
  .topbar { background: var(--color-bg-primary); color: var(--color-text-inverse-soft); font-size: .76rem; }
  .topbar__inner { display: flex; min-height: 34px; align-items: center; justify-content: space-between; gap: 1rem; }
  .topbar__inner div { display: flex; gap: .65rem; }
  .topbar a:hover { color: var(--color-link-inverse-hover); text-decoration: underline; }
  .header-main { background: var(--color-backdrop-surface); backdrop-filter: blur(12px); }
  .header-main__inner { display: flex; min-height: 78px; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .brand { display: flex; flex: 0 1 390px; align-items: center; gap: .75rem; }
  .brand__logo { width: 58px; height: 58px; flex: 0 0 auto; object-fit: contain; }
  .brand__text { display: grid; line-height: 1.1; }
  .brand strong { font: 700 .92rem 'Manrope'; letter-spacing: -.02em; }
  .brand small { margin-top: .28rem; color: var(--muted); font-size: .66rem; }
  @media (max-width: 1060px) { .brand { flex-basis: auto; }.brand__text { display: none; } }
  @media (max-width: 720px) { .topbar p, .topbar span, .topbar a:last-child { display: none; }.topbar__inner { justify-content: center; }.header-main__inner { min-height: 70px; } }
</style>
