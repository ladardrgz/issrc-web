---
const { post } = Astro.props;
const date = post.data.date.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
---
<article class="news-card" data-news-card data-title={post.data.title.toLowerCase()} data-search={`${post.data.title} ${post.data.description} ${post.data.category}`.toLowerCase()} data-category={post.data.category} data-date={post.data.date.toISOString()}>
  <a class="news-card__image" href={`/noticias/${post.id}/`} aria-label={`Leer ${post.data.title}`}><span aria-hidden="true">ISS</span><small>Imagen institucional</small></a>
  <div class="news-card__content"><div class="news-card__meta"><span class="badge">{post.data.category}</span><time datetime={post.data.date.toISOString()}>{date}</time></div><h3><a href={`/noticias/${post.id}/`}>{post.data.title}</a></h3><p>{post.data.description}</p><a class="text-link" href={`/noticias/${post.id}/`}>Leer más →</a></div>
</article>
<style>
  .news-card { overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius); background: var(--white); }.news-card__image { display: grid; min-height: 210px; place-content: center; background: linear-gradient(145deg, var(--green-deep), var(--green-dark)); color: var(--mint); text-align: center; }.news-card__image span { font: 800 2.5rem 'Manrope'; }.news-card__image small { color: #b9cdc1; }.news-card__content { padding: 1.5rem; }.news-card__meta { display: flex; flex-wrap: wrap; align-items: center; gap: .7rem; margin-bottom: 1rem; color: var(--muted); font-size: .76rem; }.news-card h3 a:hover { color: var(--green); }.news-card p { margin-top: .7rem; color: var(--muted); }
</style>
