---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'noticias'>;
}

const { post } = Astro.props;
const { title, slug, date, category, summary, featuredImage } = post.data;
const formattedDate = date.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const href = `/noticias/${slug}/`;
---

<article
  class="news-card"
  data-news-card
  data-title={title.toLowerCase()}
  data-search={`${title} ${summary ?? ''} ${category}`.toLowerCase()}
  data-category={category}
  data-date={date.toISOString()}
>
  <a class:list={['news-card__image', { 'news-card__image--placeholder': !featuredImage }]} href={href} aria-label={`Leer ${title}`}>
    {featuredImage ? (
      <img src={featuredImage} alt="" loading="lazy" width="720" height="405" />
    ) : (
      <><span aria-hidden="true">ISS</span><small>Noticia institucional</small></>
    )}
  </a>
  <div class="news-card__content">
    <div class="news-card__meta">
      <span class="badge">{category}</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h3><a href={href}>{title}</a></h3>
    {summary && <p>{summary}</p>}
    <a class="text-link" href={href}>Leer más →</a>
  </div>
</article>

<style>
  .news-card { overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius); background: var(--white); }
  .news-card__image { display: block; aspect-ratio: 16 / 9; overflow: hidden; background: var(--surface); }
  .news-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform .25s ease; }
  .news-card__image:hover img { transform: scale(1.025); }
  .news-card__image--placeholder { display: grid; place-content: center; background: linear-gradient(145deg, var(--green-deep), var(--green-dark)); color: var(--mint); text-align: center; }
  .news-card__image--placeholder span { font: 800 2.5rem 'Manrope'; }
  .news-card__image--placeholder small { color: #b9cdc1; }
  .news-card__content { padding: 1.5rem; }
  .news-card__meta { display: flex; flex-wrap: wrap; align-items: center; gap: .7rem; margin-bottom: 1rem; color: var(--muted); font-size: .76rem; }
  .news-card h3 a:hover { color: var(--green); }
  .news-card p { margin-top: .7rem; color: var(--muted); }
</style>
