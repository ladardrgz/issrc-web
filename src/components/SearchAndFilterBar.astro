---
const { categories = [], years = [] } = Astro.props as { categories: string[]; years: string[] };
---
<form class="filters" id="news-filters" role="search">
  <div class="field field--search"><label for="search">Buscar noticias</label><input id="search" type="search" placeholder="Título o palabra clave" /></div>
  <div class="field"><label for="category">Categoría</label><select id="category"><option value="">Todas</option>{categories.map((category) => <option value={category}>{category}</option>)}</select></div>
  <div class="field"><label for="year">Fecha</label><select id="year"><option value="">Todos los años</option>{years.map((year) => <option value={year}>{year}</option>)}</select></div>
  <div class="field"><label for="sort">Ordenar</label><select id="sort"><option value="recent">Más recientes</option><option value="oldest">Más antiguas</option><option value="relevance">Relevancia</option></select></div>
  <button type="reset">Limpiar filtros</button>
</form>
<p class="results-count" id="results-count" aria-live="polite"></p>
<script>
  const form = document.querySelector<HTMLFormElement>('#news-filters');
  const grid = document.querySelector<HTMLElement>('#news-grid');
  const count = document.querySelector<HTMLElement>('#results-count');
  const cards = [...document.querySelectorAll<HTMLElement>('[data-news-card]')];
  const update = () => {
    if (!form || !grid) return;
    const search = (form.querySelector<HTMLInputElement>('#search')?.value ?? '').trim().toLowerCase();
    const category = form.querySelector<HTMLSelectElement>('#category')?.value ?? '';
    const year = form.querySelector<HTMLSelectElement>('#year')?.value ?? '';
    const sort = form.querySelector<HTMLSelectElement>('#sort')?.value ?? 'recent';
    let visible = cards.filter((card) => (!search || card.dataset.search?.includes(search)) && (!category || card.dataset.category === category) && (!year || card.dataset.date?.startsWith(year)));
    visible.sort((a,b) => sort === 'oldest' ? (a.dataset.date ?? '').localeCompare(b.dataset.date ?? '') : sort === 'relevance' && search ? Number(!a.dataset.title?.startsWith(search)) - Number(!b.dataset.title?.startsWith(search)) : (b.dataset.date ?? '').localeCompare(a.dataset.date ?? ''));
    cards.forEach((card) => card.hidden = true); visible.forEach((card) => { card.hidden = false; grid.append(card); });
    if (count) count.textContent = `${visible.length} ${visible.length === 1 ? 'noticia encontrada' : 'noticias encontradas'}`;
  };
  form?.addEventListener('input', update); form?.addEventListener('reset', () => setTimeout(update)); update();
</script>
<style>
  .filters { display: grid; grid-template-columns: 2fr repeat(3, 1fr) auto; gap: .8rem; align-items: end; margin-bottom: 1rem; padding: 1.2rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--white); box-shadow: 0 12px 35px rgba(5,31,32,.06); }.filters button { min-height: 48px; padding: .7rem 1rem; border: 1px solid var(--line); border-radius: .75rem; background: var(--surface); color: var(--green-dark); cursor: pointer; font-weight: 700; }.results-count { margin-bottom: 2rem; color: var(--muted); font-size: .85rem; }
  @media (max-width: 960px) { .filters { grid-template-columns: 1fr 1fr; }.field--search { grid-column: 1 / -1; } }
  @media (max-width: 560px) { .filters { grid-template-columns: 1fr; }.field--search { grid-column: auto; } }
</style>
