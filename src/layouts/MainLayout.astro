---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import '../styles/global.css';
interface Props { title: string; description?: string; image?: string; type?: 'website' | 'article'; }
const { title, description = site.description, image = '/og-default.svg', type = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const fullTitle = title === 'Inicio' ? site.name : `${title} | Instituto Ramón Carrillo`;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: site.name,
  url: canonical.origin,
  email: site.email,
  telephone: site.phones[0].label,
  address: { '@type': 'PostalAddress', streetAddress: 'Córdoba 447', addressLocality: 'Formosa', addressRegion: 'Formosa', addressCountry: 'AR' },
  sameAs: [site.social.instagram, site.social.facebook],
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#153A5B" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href="/images/branding/icono-pestaña.ico" />
    <link rel="shortcut icon" href="/images/branding/icono-pestaña.ico" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, canonical.origin)} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>ISS</title>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body><a class="skip-link" href="#contenido">Saltar al contenido</a><Header /><main id="contenido"><slot /></main><Footer /></body>
</html>
