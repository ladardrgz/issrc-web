---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Página no encontrada"><section class="section section--dark"><div class="container not-found"><span>404</span><h1>Página no encontrada</h1><p class="lead">La dirección puede haber cambiado o el contenido ya no está disponible.</p><a class="button button--light" href="/">Volver al inicio →</a></div></section></MainLayout><style>.not-found{display:grid;min-height:55vh;place-items:start;align-content:center}.not-found>span{color:var(--mint);font-size:1.2rem;font-weight:800}.not-found p{margin:1rem 0 2rem}</style>
