---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const posts = await getCollection('noticias', ({ data }) => data.status === 'published');
  return posts.map((post) => ({ params: { id: post.id }, props: { slug: post.data.slug } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.props;
return Astro.redirect(`/noticias/${slug}/`, 301);
---
