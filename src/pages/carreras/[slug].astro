---
import type { GetStaticPaths } from 'astro';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { careers, type Career } from '../../data/careers';
export const getStaticPaths = (() => careers.map((career) => ({ params: { slug: career.slug }, props: { career } }))) satisfies GetStaticPaths;
const { career } = Astro.props as { career: Career };
const faqSchema = { '@context':'https://schema.org','@type':'FAQPage',mainEntity:career.faqs.map((faq)=>({'@type':'Question',name:faq.question,acceptedAnswer:{'@type':'Answer',text:faq.answer}})) };
---
<MainLayout title={`${career.name} en Formosa`} description={`Conocé duración, modalidad, perfil profesional, campo laboral y requisitos para estudiar ${career.name} en Formosa.`}>
  <Breadcrumbs items={[{label:'Carreras',href:'/carreras/'},{label:career.name}]} />
  <section class="career-hero"><div class="container career-hero__grid"><div><span class="eyebrow">Carrera · Formosa</span><h1>{career.name}</h1><p>{career.description}</p><div class="career-hero__actions"><a class="button button--light" href={`/contacto/?carrera=${encodeURIComponent(career.name)}`}>Consultar inscripción</a></div></div><div class="career-cover"><strong>RC</strong><span>[Imagen de portada de la carrera]</span></div></div></section>
  <section class="facts"><div class="container facts__grid"><div><span>Nivel</span><strong>{career.level}</strong></div><div><span>Modalidad</span><strong>{career.modality}</strong></div><div><span>Duración</span><strong>{career.duration}</strong></div><div><span>Título otorgado</span><strong>{career.awardedTitle}</strong></div></div></section>
  <section class="section"><div class="container content-grid"><aside><nav aria-label="Contenido de la carrera"><a href="#descripcion">Descripción</a><a href="#perfil">Perfil profesional</a><a href="#campo">Campo laboral</a><a href="#plan">Plan de estudio</a><a href="#ingreso">Ingreso</a><a href="#preguntas">Preguntas frecuentes</a></nav></aside><div class="career-content"><section id="descripcion"><span class="eyebrow">Presentación</span><h2>Descripción general</h2><p>{career.description}</p><h3>Rol del egresado</h3><p>{career.graduateRole}</p></section><section id="perfil"><span class="eyebrow">Competencias</span><h2>Perfil profesional</h2><ul>{career.professionalProfile.map((item)=><li>{item}</li>)}</ul></section><section id="campo"><span class="eyebrow">Desarrollo profesional</span><h2>Campo laboral</h2><ul>{career.careerOpportunities.map((item)=><li>{item}</li>)}</ul></section><section id="plan"><span class="eyebrow">Trayecto académico</span><h2>Plan de estudio</h2>{career.curriculum.map((group)=><details open><summary>{group.year}</summary><ul>{group.subjects.map((subject)=><li>{subject}</li>)}</ul></details>)}</section><section id="ingreso"><span class="eyebrow">Ingresantes</span><h2>Requisitos de inscripción</h2><ul>{career.admissionRequirements.map((item)=><li>{item}</li>)}</ul><h3>Documentación necesaria</h3><ul>{career.requiredDocuments.map((item)=><li>{item}</li>)}</ul></section><section id="preguntas"><span class="eyebrow">Información útil</span><h2>Preguntas frecuentes</h2>{career.faqs.map((faq)=><details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}</section></div></div></section>
  <section class="section section--dark"><div class="container final-cta"><div><span class="eyebrow">¿Necesitás orientación?</span><h2>Consultá sobre esta carrera</h2><p class="lead">El equipo institucional responderá tus preguntas sobre ingreso y documentación.</p></div><a class="button button--light" href={`/contacto/?carrera=${encodeURIComponent(career.name)}`}>Realizar una consulta →</a></div></section>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</MainLayout>
<style>.career-hero{padding:clamp(4rem,8vw,7rem) 0;background:var(--green-dark);color:var(--white)}.career-hero__grid{display:grid;grid-template-columns:1.2fr .8fr;gap:4rem;align-items:center}.career-hero p{max-width:650px;margin-top:1.2rem;color:#c3d5cb;font-size:1.1rem}.career-hero__actions{margin-top:2rem}.career-cover{display:grid;min-height:350px;place-content:center;border:1px solid rgba(255,255,255,.18);border-radius:10rem 10rem 1rem 1rem;background:var(--green-deep);color:var(--mint);text-align:center}.career-cover strong{font:800 4rem 'Manrope'}.career-cover span{display:block;color:#bfd0c6}.facts{border-bottom:1px solid var(--line);background:var(--white)}.facts__grid{display:grid;grid-template-columns:repeat(4,1fr)}.facts__grid div{padding:1.4rem;border-right:1px solid var(--line)}.facts span{display:block;color:var(--muted);font-size:.75rem;text-transform:uppercase}.facts strong{display:block;margin-top:.3rem}.content-grid{display:grid;grid-template-columns:230px 1fr;gap:clamp(2rem,7vw,7rem);align-items:start}.content-grid aside{position:sticky;top:140px}.content-grid nav{display:grid;border-left:2px solid var(--line)}.content-grid nav a{padding:.5rem 1rem;color:var(--muted);font-size:.85rem}.content-grid nav a:hover{border-left:2px solid var(--green);color:var(--green);transform:translateX(-2px)}.career-content{max-width:760px}.career-content section+section{margin-top:5rem}.career-content h2+*,.career-content h3+*{margin-top:1rem}.career-content h3{margin-top:2rem}.career-content ul{display:grid;gap:.55rem;padding-left:1.2rem;color:var(--muted)}details{margin-top:.8rem;padding:1rem 1.2rem;border:1px solid var(--line);border-radius:.8rem;background:var(--white)}summary{cursor:pointer;font-weight:700}details p,details ul{margin-top:1rem}.final-cta{display:flex;align-items:center;justify-content:space-between;gap:2rem}@media(max-width:800px){.career-hero__grid,.content-grid{grid-template-columns:1fr}.career-cover,.content-grid aside{display:none}.facts__grid{grid-template-columns:1fr 1fr}.final-cta{align-items:flex-start;flex-direction:column}}@media(max-width:500px){.facts__grid{grid-template-columns:1fr}.facts__grid div{border-right:0;border-bottom:1px solid var(--line)}}</style>
