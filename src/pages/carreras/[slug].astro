---
import type { GetStaticPaths } from 'astro';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CareerDetail from '../../components/CareerDetail.astro';
import { careers, type Career } from '../../data/careers';

export const getStaticPaths = (() =>
  careers.map((career) => ({
    params: { slug: career.slug },
    props: { career },
  }))) satisfies GetStaticPaths;

const { career } = Astro.props as { career: Career };
---

<MainLayout title={career.title} description={career.description}>
  <Breadcrumbs items={[{ label: 'Carreras', href: '/carreras/' }, { label: career.title }]} />
  <CareerDetail career={career} />
</MainLayout>
