---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CareerCard from '../../components/CareerCard.astro';
import InstitutionalSidebar from '../../components/InstitutionalSidebar.astro';
import { careers } from '../../data/careers';
---
<MainLayout title="Oferta Académica" description="Conocé las carreras y propuestas de formación sanitaria del Instituto Ramón Carrillo en Formosa.">
  <Breadcrumbs items={[{label:'Carreras'}]} />
  <section class="page-hero"><div class="container"><span class="eyebrow">Oferta Académica</span><h1>Formación superior para el ámbito de la salud</h1><p class="lead">Explorá nivel, modalidad, duración, perfil profesional y requisitos de cada carrera.</p></div></section>
  <section class="section"><div class="container editorial-shell"><div class="editorial-main"><div class="section-heading"><div><span class="eyebrow">Carreras</span><h2>Encontrá tu propuesta académica</h2></div><p class="lead">El listado definitivo se completará únicamente con carreras e información oficialmente confirmadas.</p></div><div class="grid grid--2">{careers.map((career)=><CareerCard career={career}/>)}</div></div><InstitutionalSidebar title="Oferta académica" links={[{label:'Todas las carreras',href:'/carreras/'},{label:'Requisitos de ingreso',href:'/ingresantes/'},{label:'Documentación',href:'/ingresantes/#documentacion'},{label:'Consultar inscripción',href:'/contacto/'}]} /></div></section>
  <section class="section section--soft"><div class="container split"><div><span class="eyebrow">Ingresantes</span><h2>Información para empezar</h2><p class="lead">Consultá requisitos, documentación y canales habilitados para recibir orientación.</p></div><a class="button" href="/ingresantes/">Ver información de ingreso →</a></div></section>
</MainLayout>
