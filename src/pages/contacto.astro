---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../data/site';
---
<MainLayout title="Contacto" description="Contactate con el Instituto Superior de Sanidad Ramón Carrillo en Córdoba 447, Formosa Capital.">
  <Breadcrumbs items={[{label:'Contacto'}]} />
  <section class="page-hero"><div class="container"><span class="eyebrow">Contacto</span><h1>Estamos para orientarte</h1><p class="lead">Consultá sobre carreras, requisitos e información institucional mediante nuestros canales oficiales.</p></div></section>
  <section class="section"><div class="container contact-grid"><div><span class="eyebrow">Datos institucionales</span><h2>Comunicate con el Instituto</h2><p class="lead">El Instituto Superior de Sanidad "Prof. Dr. Ramón Carrillo" es la excelencia y profesionalismo en enseñanza sanitaria de Formosa.</p><div class="contact-list"><p><span>Dirección</span>{site.address}</p><p><span>Informes e Inscripción</span><a href={`mailto:${site.email}`}>{site.email}</a></p><p><span>Teléfonos</span>{site.phones.map((phone)=><a href={phone.href}>{phone.label}</a>)}</p><p><span>Redes sociales</span><a href={site.social.instagram} target="_blank" rel="noopener noreferrer">Instagram ↗</a> · <a href={site.social.facebook} target="_blank" rel="noopener noreferrer">Facebook ↗</a></p></div></div><div class="contact-panel"><h3>Enviar una consulta</h3><p>Al continuar, se abrirá tu aplicación de correo con la dirección institucional.</p><a class="button" href={`mailto:${site.email}?subject=Consulta%20desde%20el%20sitio%20web`}>Escribir por correo →</a><a class="gmail-link" href={site.social.email} target="_blank" rel="noopener noreferrer">Abrir en Gmail ↗</a><hr/><h3>WhatsApp</h3><p>[Número oficial de WhatsApp pendiente de confirmación]</p></div></div></section>
  <section class="section section--soft"><div class="container"><div class="section-heading"><div><span class="eyebrow">Ubicación</span><h2>Encontranos en Formosa Capital</h2></div><p class="lead">Córdoba 447, Formosa.</p></div><div class="map"><iframe title="Ubicación del Instituto Superior de Sanidad Ramón Carrillo" src="https://www.google.com/maps?q=C%C3%B3rdoba%20447%2C%20Formosa%2C%20Argentina&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe></div></div></section>
</MainLayout>
<style>.contact-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:clamp(2rem,7vw,6rem);align-items:start}.contact-panel{padding:2rem;border:1px solid var(--line);border-radius:var(--radius);background:var(--white);box-shadow:var(--shadow)}.contact-panel>p{margin:.7rem 0 1.4rem;color:var(--muted)}.contact-panel hr{margin:2rem 0;border:0;border-top:1px solid var(--line)}.gmail-link{display:block;margin-top:1rem;color:var(--green);font-weight:700}.map{overflow:hidden;border-radius:var(--radius);background:var(--surface)}.map iframe{display:block;width:100%;height:430px;border:0}@media(max-width:760px){.contact-grid{grid-template-columns:1fr}}</style>
