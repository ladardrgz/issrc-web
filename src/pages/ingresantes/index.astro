---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InstitutionalSidebar from '../../components/InstitutionalSidebar.astro';

const requisitosInscripcion = [
  'Ficha de inscripción (se confecciona en el ISS).',
  'Firma del Acta de Compromiso (se retira en el ISS).',
  'Ficha médica (se retira del ISS).',
  'Carpeta colgante con borde y accesorios plásticos (color acorde a la tecnicatura).',
  'Vacunas: antitetánica y hepatitis.',
  'Fotocopia del DNI.',
  'Fotocopia de la partida de nacimiento.',
  'Fotocopia del Título Secundario o constancia de título en trámite.',
  'Tres (3) fotos color 4x4.',
  'Constancia de trabajo, si trabaja.',
  'Matrícula.',
];
---

<MainLayout title="Ingresantes" description="Información para ingresantes: requisitos, documentación y consultas de inscripción del Instituto Ramón Carrillo en Formosa.">
  <Breadcrumbs items={[{ label: 'Ingresantes' }]} />

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Ingresantes</span>
      <h1>Todo lo necesario para comenzar</h1>
      <p class="lead">Encontrá información general y comunicate con el Instituto para confirmar condiciones, fechas y disponibilidad.</p>
    </div>
  </section>

  <section class="section">
    <div class="container editorial-shell">
      <div class="editorial-main">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Ingreso</span>
            <h2>Información de inscripción</h2>
          </div>
          <p class="lead">Este sitio no procesa inscripciones. Las consultas se reciben mediante los canales institucionales.</p>
        </div>

        <div class="grid grid--3">
          <article class="card ingress-card">
            <span class="card__icon ingress-card__number">01</span>
            <h3>Elegí una carrera</h3>
            <p>Revisá la oferta académica, modalidad, duración y perfil profesional.</p>
            <a class="text-link" href="/carreras/">Ver carreras →</a>
          </article>

          <article class="card ingress-card">
            <span class="card__icon ingress-card__number">02</span>
            <h3>Reuní la documentación</h3>
            <ul class="compact-doc-list">
              {requisitosInscripcion.slice(0, 5).map((item) => <li>{item}</li>)}
            </ul>
            <a class="text-link" href="#requisitos">Ver listado completo →</a>
          </article>

          <article class="card ingress-card">
            <span class="card__icon ingress-card__number">03</span>
            <h3>Realizá tu consulta</h3>
            <p>Confirmá fechas, cupos y requisitos directamente con el Instituto.</p>
            <a class="text-link" href="/contacto/">Contactar →</a>
          </article>
        </div>
      </div>

      <InstitutionalSidebar
        title="Guía de ingreso"
        links={[
          { label: 'Elegir una carrera', href: '/carreras/' },
          { label: 'Requisitos generales', href: '#requisitos' },
          { label: 'Preguntas frecuentes', href: '#preguntas' },
          { label: 'Realizar una consulta', href: '/contacto/' },
        ]}
      />
    </div>
  </section>

  <section class="section section--soft" id="requisitos">
    <div class="container split">
      <div>
        <span class="eyebrow">Requisitos generales</span>
        <h2>Antes de consultar</h2>
        <ul class="check-list">
          {requisitosInscripcion.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="card">
        <h3>Importante</h3>
        <p>Las condiciones pueden variar según la carrera. La información definitiva debe confirmarse con el Instituto.</p>
        <p><strong>Correo:</strong> contacto@issformosa.edu.ar</p>
        <p><strong>Teléfonos:</strong> (3704) 421840 / 431868</p>
      </div>
    </div>
  </section>

  <section class="section" id="preguntas">
    <div class="container">
      <span class="eyebrow">Preguntas frecuentes</span>
      <h2>Consultas habituales</h2>
      <div class="faqs">
        <details><summary>¿Puedo inscribirme desde este sitio?</summary><p>No. El sitio brinda información y acceso a los canales oficiales de consulta.</p></details>
        <details><summary>¿Dónde confirmo fechas de inscripción?</summary><p>Comunicate mediante el correo o los teléfonos institucionales publicados.</p></details>
        <details><summary>¿El Campus Virtual gestiona nuevas inscripciones?</summary><p>El Campus es un entorno externo destinado a la actividad académica. Consultá al Instituto para conocer el proceso de ingreso.</p></details>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container final">
      <div>
        <h2>¿Necesitás más información?</h2>
        <p class="lead">Nuestro equipo puede orientarte sobre carreras e ingreso.</p>
      </div>
      <a class="button button--light" href="/contacto/">Realizar una consulta →</a>
    </div>
  </section>
</MainLayout>

<style>
  .ingress-card__number {
    background: color-mix(in srgb, var(--color-secondary) 16%, transparent);
    color: var(--color-secondary);
    box-shadow: 0 0 0 .35rem color-mix(in srgb, var(--color-secondary) 8%, transparent);
  }

  .compact-doc-list,
  .check-list {
    display: grid;
    gap: .65rem;
    margin-top: 1rem;
    padding: 0;
    list-style: none;
  }

  .compact-doc-list li,
  .check-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: .65rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .compact-doc-list li::before,
  .check-list li::before {
    width: .55rem;
    height: .55rem;
    margin-top: .52rem;
    border-radius: 999px;
    background: var(--color-secondary);
    content: '';
  }

  .check-list li {
    padding: .85rem 0;
    border-bottom: 1px solid var(--line);
  }

  .faqs {
    display: grid;
    gap: .8rem;
    max-width: 850px;
    margin-top: var(--space-stack-gap);
  }

  .faqs details {
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: .8rem;
    background: var(--white);
  }

  .faqs summary {
    cursor: pointer;
    font-weight: 700;
  }

  .faqs p {
    margin-top: .8rem;
    color: var(--muted);
  }

  .final {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  @media(max-width:650px) {
    .final {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
