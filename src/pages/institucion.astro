---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHeader from '../components/SectionHeader.astro';
import InstitutionalSidebar from '../components/InstitutionalSidebar.astro';
---
<MainLayout title="Institución" description="Conocé la historia, misión, visión y valores del Instituto Superior de Sanidad Prof. Dr. Ramón Carrillo - Fundación HAC en Formosa.">
  <Breadcrumbs items={[{label:'Institución'}]} />
  <section class="page-hero"><div class="container"><span class="eyebrow">Institución</span><h1>Educación sanitaria al servicio de la comunidad</h1><p class="lead">Conocé los principios, la organización y el recorrido del Instituto Superior de Sanidad Prof. Dr. Ramón Carrillo - Fundación HAC.</p></div></section>
  <section class="section"><div class="container editorial-shell"><div class="editorial-main split"><div class="prose"><span class="eyebrow">Historia</span><h2>Una trayectoria vinculada con la formación sanitaria</h2><p class="lead">[Reseña histórica oficial de la institución]</p><p>Este bloque está preparado para presentar hitos, antecedentes y evolución institucional sin recurrir a cifras o fechas no verificadas.</p></div><div class="placeholder-media"><div><strong>[Imagen institucional histórica]</strong><p>Fotografía y referencia documental a confirmar.</p></div></div></div><InstitutionalSidebar title="Institución" links={[{label:'Historia',href:'#historia'},{label:'Misión y visión',href:'#mision'},{label:'Autoridades',href:'#autoridades'},{label:'Fundación HAC',href:'#fundacion'},{label:'Convenios',href:'#convenios'}]} /></div></section>
  <section class="section section--soft"><div class="container"><div class="grid grid--2"><article class="principle"><span>01</span><h2>Misión</h2><p>[Declaración oficial de la misión institucional]</p></article><article class="principle"><span>02</span><h2>Visión</h2><p>[Declaración oficial de la visión institucional]</p></article></div></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Identidad" title="Valores institucionales" description="Principios que orientan la actividad académica y el vínculo con la comunidad."/><div class="grid grid--3">{['[Valor institucional]','[Valor institucional]','[Valor institucional]'].map((value,index)=><article class="card"><span class="card__icon">{String(index+1).padStart(2,'0')}</span><h3>{value}</h3><p>[Descripción oficial del valor]</p></article>)}</div></div></section>
  <section class="section section--dark"><div class="container"><SectionHeader eyebrow="Propósito" title="Fines institucionales" description="[Presentación oficial de los fines educativos, sanitarios y comunitarios]"/><div class="purpose-list"><p>01 · [Fin institucional a confirmar]</p><p>02 · [Fin institucional a confirmar]</p><p>03 · [Fin institucional a confirmar]</p></div></div></section>
  <section class="section"><div class="container"><SectionHeader eyebrow="Organización" title="Autoridades" description="Equipo responsable de la conducción institucional."/><div class="grid grid--3">{['[Nombre de autoridad]','[Nombre de autoridad]','[Nombre de autoridad]'].map((name)=><article class="card"><span class="card__icon" aria-hidden="true">○</span><h3>{name}</h3><p>[Cargo institucional]</p></article>)}</div></div></section>
  <section class="section section--soft" id="fundacion"><div class="container split"><div><span class="eyebrow">Fundación HAC</span><h2>Marco institucional</h2><p class="lead">[Información oficial sobre Fundación HAC y su relación con el Instituto]</p></div><div class="card"><h3>Documentación institucional</h3><p>[Resoluciones, reconocimientos y documentación pública disponible]</p><span class="text-link">Documentación pendiente de publicación</span></div></div></section>
  <section class="section" id="convenios"><div class="container"><SectionHeader eyebrow="Vinculación" title="Convenios y reconocimientos" description="Acuerdos y antecedentes que fortalecen la actividad institucional."/><div class="empty-state"><h3>Información a confirmar</h3><p>Los convenios se publicarán cuando se disponga de documentación oficial.</p></div></div></section>
</MainLayout>
<style>.principle{min-height:300px;padding:2.2rem;border-radius:var(--radius);background:var(--white)}.principle span{color:var(--mint);font-weight:800}.principle h2{margin-top:3rem}.principle p{margin-top:1rem;color:var(--muted)}.purpose-list{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.purpose-list p{padding:1.5rem;border:1px solid rgba(255,255,255,.15);border-radius:var(--radius);color:#d2e0d8}@media(max-width:700px){.purpose-list{grid-template-columns:1fr}}</style>
